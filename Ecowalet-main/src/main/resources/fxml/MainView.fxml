<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.MainController"
      spacing="14"
      style="-fx-background-color: #f5f9f5; -fx-padding: 20;">

    <!-- ── Cabeçalho ─────────────────────────────────────────────────────────── -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="🌿 EcoWallet"
               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #2d6a4f;"/>
        <Label text="Gestão Financeira Consciente"
               style="-fx-font-size: 13px; -fx-text-fill: #74c69d;"/>
    </HBox>

    <Separator/>

    <!-- ── Formulário de entrada ──────────────────────────────────────────────── -->
    <VBox spacing="8"
          style="-fx-background-color: #ffffff; -fx-padding: 14; -fx-background-radius: 8;
                 -fx-effect: dropshadow(gaussian, #d8e8d8, 6, 0, 0, 2);">

        <Label text="Nova Transação"
               style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #40916c;"/>

        <HBox spacing="10" alignment="CENTER_LEFT">

            <TextField fx:id="tfDescricao"
                       promptText="Descrição (ex: Salário, Mercado...)"
                       style="-fx-pref-width: 260px;"/>

            <TextField fx:id="tfValor"
                       promptText="Valor (R$)"
                       style="-fx-pref-width: 120px;"/>

            <ComboBox fx:id="cbTipo"
                      promptText="Tipo"
                      style="-fx-pref-width: 110px;"/>

            <ComboBox fx:id="cbCategoria"
                      promptText="Categoria"
                      style="-fx-pref-width: 140px;"/>

            <Button fx:id="btnAdicionar"
                    text="＋ Adicionar"
                    onAction="#handleAdicionar"
                    style="-fx-background-color: #40916c; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-background-radius: 5;
                           -fx-cursor: hand;"/>

            <Button fx:id="btnRemover"
                    text="✕ Remover"
                    onAction="#handleRemover"
                    style="-fx-background-color: #e63946; -fx-text-fill: white;
                           -fx-font-weight: bold; -fx-background-radius: 5;
                           -fx-cursor: hand;"/>
        </HBox>

        <!-- Mensagem de erro de validação -->
        <Label fx:id="lblErro"
               text=""
               style="-fx-text-fill: #e63946; -fx-font-size: 12px;"/>
    </VBox>

    <!-- ── Tabela de transações ───────────────────────────────────────────────── -->
    <TableView fx:id="tableView"
               VBox.vgrow="ALWAYS"
               style="-fx-background-radius: 8;">
        <columns>
            <TableColumn fx:id="colTipo"      text="Tipo"      prefWidth="90"/>
            <TableColumn fx:id="colDescricao" text="Descrição" prefWidth="240"/>
            <TableColumn fx:id="colValor"     text="Valor (R$)" prefWidth="120"/>
            <TableColumn fx:id="colCategoria" text="Categoria" prefWidth="130"/>
            <TableColumn fx:id="colData"      text="Data"      prefWidth="110"/>
        </columns>
        <placeholder>
            <Label text="Nenhuma transação registrada ainda."
                   style="-fx-text-fill: #adb5bd;"/>
        </placeholder>
    </TableView>

    <!-- ── Rodapé com saldo ───────────────────────────────────────────────────── -->
    <HBox alignment="CENTER_RIGHT" spacing="8"
          style="-fx-background-color: #ffffff; -fx-padding: 12;
                 -fx-background-radius: 8;
                 -fx-effect: dropshadow(gaussian, #d8e8d8, 6, 0, 0, 2);">
        <Label text="Saldo Total:"
               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #495057;"/>
        <Label fx:id="lblSaldo"
               text="R$ 0,00"
               style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
    </HBox>

</VBox>
